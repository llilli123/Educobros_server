@model Educobros.Models.Estudiante

@{
    ViewData["Title"] = "Nuevo Estudiante";
}

<style>
    .student-create-page {
        min-height: calc(100vh - 120px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
        background: radial-gradient(circle at top left, rgba(91, 108, 255, 0.18), transparent 25%), radial-gradient(circle at bottom right, rgba(166, 28, 255, 0.12), transparent 25%), linear-gradient(135deg, #050816, #0b1020 45%, #0d1226);
        border-radius: 24px;
    }

    .student-card {
        width: 100%;
        max-width: 920px;
        background: linear-gradient(180deg, rgba(20, 25, 41, 0.94), rgba(13, 17, 31, 0.98));
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 28px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.35);
        overflow: hidden;
        color: #f8fafc;
    }

    .student-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.7rem 1.8rem;
        border-bottom: 1px solid rgba(255,255,255,0.07);
    }

    .student-header-left {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
    }

    .student-header-icon {
        width: 54px;
        height: 54px;
        border-radius: 18px;
        background: linear-gradient(135deg, #5b6cff, #a61cff);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: white;
        box-shadow: 0 10px 24px rgba(121, 78, 255, 0.28);
        flex-shrink: 0;
    }

    .student-title {
        font-size: 2.2rem;
        font-weight: 800;
        margin: 0;
        color: #ffffff;
    }

    .student-subtitle {
        margin-top: 0.25rem;
        color: #94a3b8;
        font-size: 1.05rem;
    }

    .student-close {
        color: #a9b2c5;
        font-size: 2rem;
        text-decoration: none;
        line-height: 1;
    }

        .student-close:hover {
            color: #ffffff;
        }

    .student-card-body {
        padding: 1.8rem;
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1.55rem;
        font-weight: 800;
        color: #ffffff;
        margin: 0 0 1.35rem 0;
    }

        .section-title span {
            font-size: 1.15rem;
        }

    .section-block {
        margin-bottom: 2rem;
    }

    .form-grid-2 {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.25rem;
    }

    .form-grid-1 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.25rem;
    }

    .field-block {
        margin-bottom: 0.2rem;
    }

    .form-label-modern {
        color: #d8deea;
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 0.7rem;
        display: block;
    }

    .input-shell {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #7f8aa3;
        font-size: 1.1rem;
        pointer-events: none;
        z-index: 2;
    }

    .form-control-modern,
    .form-select-modern {
        width: 100%;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.05);
        color: #ffffff;
        font-size: 1.08rem;
        padding: 1rem 1rem 1rem 3.15rem;
        outline: none;
        transition: 0.2s ease;
        box-shadow: none;
    }

        .form-control-modern:focus,
        .form-select-modern:focus {
            border-color: rgba(91, 108, 255, 0.7);
            box-shadow: 0 0 0 0.2rem rgba(91, 108, 255, 0.15);
            background: rgba(255,255,255,0.07);
            color: #ffffff;
        }

        .form-control-modern::placeholder {
            color: #7f8aa3;
        }

        .form-select-modern option {
            color: #111827;
        }

    .divider-line {
        border: 0;
        border-top: 1px solid rgba(255,255,255,0.07);
        margin: 1.5rem 0 0 0;
    }

    .actions-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-top: 1.8rem;
    }

    .btn-cancel-modern,
    .btn-submit-modern {
        border: none;
        border-radius: 18px;
        padding: 1rem 1.2rem;
        font-size: 1.15rem;
        font-weight: 800;
        text-align: center;
        text-decoration: none;
        transition: 0.2s ease;
    }

    .btn-cancel-modern {
        background: rgba(255,255,255,0.08);
        color: #d4d9e4;
    }

        .btn-cancel-modern:hover {
            background: rgba(255,255,255,0.12);
            color: white;
        }

    .btn-submit-modern {
        color: white;
        background: linear-gradient(90deg, #5b6cff, #a61cff);
        box-shadow: 0 12px 28px rgba(121, 78, 255, 0.30);
    }

        .btn-submit-modern:hover {
            opacity: 0.96;
            transform: translateY(-1px);
        }

    .text-danger {
        color: #ff8da1 !important;
        font-size: 0.92rem;
        margin-top: 0.45rem;
        display: block;
    }

    .validation-summary-errors,
    .validation-summary-valid {
        margin-bottom: 1rem;
    }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 1.2rem;
            color: #ff8da1;
        }

    @@media (max-width: 768px) {
        .student-card-header,
        .student-card-body {
            padding: 1.2rem;
        }

        .student-title {
            font-size: 1.8rem;
        }

        .form-grid-2,
        .actions-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="student-create-page">
    <div class="student-card">
        <div class="student-card-header">
            <div class="student-header-left">
                <div class="student-header-icon">🎓</div>
                <div>
                    <h1 class="student-title">Nuevo Estudiante</h1>
                    <div class="student-subtitle">Completa la información del estudiante</div>
                </div>
            </div>

            <a asp-action="Index" class="student-close">×</a>
        </div>

        <div class="student-card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="section-block">
                    <h2 class="section-title">
                        <span>👤</span>
                        <span>Información Personal</span>
                    </h2>

                    <div class="form-grid-1">
                        <div class="field-block">
                            <label asp-for="Nombre" class="form-label-modern"></label>
                            <div class="input-shell">
                                <span class="input-icon">📝</span>
                                <input asp-for="Nombre" class="form-control-modern" placeholder="Ej: Carlos Martínez" />
                            </div>
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="section-block">
                    <h2 class="section-title">
                        <span>🎓</span>
                        <span>Información Académica</span>
                    </h2>

                    <div class="form-grid-2">
                        <div class="field-block">
                            <label asp-for="Grado" class="form-label-modern"></label>
                            <div class="input-shell">
                                <span class="input-icon">📚</span>
                                <select asp-for="Grado" class="form-select-modern">
                                    <option value="">Seleccionar grado</option>
                                    <option>1ro Primaria</option>
                                    <option>2do Primaria</option>
                                    <option>3ro Primaria</option>
                                    <option>4to Primaria</option>
                                    <option>5to Primaria</option>
                                    <option>6to Primaria</option>
                                    <option>1ro Sec.</option>
                                    <option>2do Sec.</option>
                                    <option>3ro Sec.</option>
                                </select>
                            </div>
                            <span asp-validation-for="Grado" class="text-danger"></span>
                        </div>

                        <div class="field-block">
                            <label asp-for="Mensualidad" class="form-label-modern"></label>
                            <div class="input-shell">
                                <span class="input-icon">$</span>
                                <input asp-for="Mensualidad" class="form-control-modern" type="number" step="0.01" placeholder="4500.00" />
                            </div>
                            <span asp-validation-for="Mensualidad" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="section-block">
                    <h2 class="section-title">
                        <span>📄</span>
                        <span>Estado de Cobro</span>
                    </h2>

                    <div class="form-grid-1">
                        <div class="field-block">
                            <label asp-for="MesesDebidos" class="form-label-modern"></label>
                            <div class="input-shell">
                                <span class="input-icon">⏳</span>
                                <input asp-for="MesesDebidos" class="form-control-modern" type="number" min="0" value="0" placeholder="0" />
                            </div>
                            <span asp-validation-for="MesesDebidos" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <hr class="divider-line" />

                <div class="actions-row">
                    <a asp-action="Index" class="btn-cancel-modern">Cancelar</a>
                    <button type="submit" class="btn-submit-modern">Guardar Estudiante</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}