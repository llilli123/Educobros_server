@model Educobros.Models.Pago

@{
    ViewData["Title"] = "Registrar Pago";
}

<style>
    .payment-create-page {
        min-height: calc(100vh - 120px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
        background: radial-gradient(circle at top left, rgba(91, 108, 255, 0.18), transparent 25%), radial-gradient(circle at bottom right, rgba(166, 28, 255, 0.12), transparent 25%), linear-gradient(135deg, #050816, #0b1020 45%, #0d1226);
        border-radius: 24px;
    }

    .payment-card {
        width: 100%;
        max-width: 760px;
        background: linear-gradient(180deg, rgba(20, 25, 41, 0.94), rgba(13, 17, 31, 0.98));
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 28px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.35);
        padding: 2rem;
        color: #f8fafc;
    }

    .payment-title {
        font-size: 2.3rem;
        font-weight: 800;
        margin: 0 0 1.8rem 0;
        color: #ffffff;
    }

    .form-label-modern {
        color: #d8deea;
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 0.7rem;
        display: block;
    }

    .field-block {
        margin-bottom: 1.35rem;
    }

    .input-shell {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #7f8aa3;
        font-size: 1.15rem;
        pointer-events: none;
        z-index: 2;
    }

    .form-control-modern,
    .form-select-modern,
    .form-textarea-modern {
        width: 100%;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.05);
        color: #ffffff;
        font-size: 1.08rem;
        padding: 1rem 1rem 1rem 3.2rem;
        outline: none;
        transition: 0.2s ease;
        box-shadow: none;
    }

    .form-textarea-modern {
        min-height: 120px;
        resize: vertical;
        padding-top: 1rem;
    }

        .form-control-modern:focus,
        .form-select-modern:focus,
        .form-textarea-modern:focus {
            border-color: rgba(91, 108, 255, 0.7);
            box-shadow: 0 0 0 0.2rem rgba(91, 108, 255, 0.15);
            background: rgba(255,255,255,0.07);
            color: #ffffff;
        }

        .form-control-modern::placeholder,
        .form-textarea-modern::placeholder {
            color: #7f8aa3;
        }

    .form-select-modern option {
        color: #111827;
    }

    .method-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.85rem;
        margin-top: 0.2rem;
    }

    .method-btn {
        border: 1px solid rgba(255,255,255,0.05);
        background: rgba(255,255,255,0.05);
        color: #aeb7ca;
        border-radius: 16px;
        padding: 0.95rem 1rem;
        font-weight: 700;
        font-size: 1rem;
        transition: 0.2s ease;
    }

        .method-btn:hover {
            background: rgba(255,255,255,0.09);
            color: white;
        }

        .method-btn.active {
            background: linear-gradient(90deg, #5b6cff, #6c5cff);
            color: white;
            border-color: transparent;
            box-shadow: 0 10px 24px rgba(91, 108, 255, 0.28);
        }

    .actions-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-top: 1.7rem;
    }

    .btn-cancel-modern,
    .btn-submit-modern {
        border: none;
        border-radius: 18px;
        padding: 1rem 1.2rem;
        font-size: 1.15rem;
        font-weight: 800;
        text-align: center;
        text-decoration: none;
        transition: 0.2s ease;
    }

    .btn-cancel-modern {
        background: rgba(255,255,255,0.08);
        color: #d4d9e4;
    }

        .btn-cancel-modern:hover {
            background: rgba(255,255,255,0.12);
            color: white;
        }

    .btn-submit-modern {
        color: white;
        background: linear-gradient(90deg, #5b6cff, #a61cff);
        box-shadow: 0 12px 28px rgba(121, 78, 255, 0.30);
    }

        .btn-submit-modern:hover {
            opacity: 0.96;
            transform: translateY(-1px);
        }

    .text-danger {
        color: #ff8da1 !important;
        font-size: 0.92rem;
        margin-top: 0.45rem;
        display: block;
    }

    .validation-summary-errors,
    .validation-summary-valid {
        margin-bottom: 1rem;
    }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 1.2rem;
            color: #ff8da1;
        }

    @@media (max-width: 768px) {
        .payment-card {
            padding: 1.3rem;
            border-radius: 22px;
        }

        .payment-title {
            font-size: 1.8rem;
        }

        .method-grid {
            grid-template-columns: 1fr;
        }

        .actions-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="payment-create-page">
    <div class="payment-card">
        <h1 class="payment-title">Registrar Nuevo Pago</h1>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="field-block">
                <label asp-for="EstudianteId" class="form-label-modern">Estudiante</label>
                <div class="input-shell">
                    <span class="input-icon">👤</span>
                    <select asp-for="EstudianteId" asp-items="ViewBag.EstudianteId" class="form-select-modern">
                        <option value="">Seleccionar estudiante</option>
                    </select>
                </div>
                <span asp-validation-for="EstudianteId" class="text-danger"></span>
            </div>

            <div class="field-block">
                <label asp-for="Concepto" class="form-label-modern">Concepto</label>
                <div class="input-shell">
                    <span class="input-icon">📝</span>
                    <input asp-for="Concepto" class="form-control-modern" placeholder="Ej: Pago mensual de abril" />
                </div>
                <span asp-validation-for="Concepto" class="text-danger"></span>
            </div>

            <div class="field-block">
                <label asp-for="Monto" class="form-label-modern">Monto</label>
                <div class="input-shell">
                    <span class="input-icon">$</span>
                    <input asp-for="Monto" class="form-control-modern" type="number" step="0.01" placeholder="150.00" />
                </div>
                <span asp-validation-for="Monto" class="text-danger"></span>
            </div>

            <div class="field-block">
                <label asp-for="Fecha" class="form-label-modern">Fecha de Pago</label>
                <div class="input-shell">
                    <span class="input-icon">📅</span>
                    <input asp-for="Fecha" type="date" class="form-control-modern" />
                </div>
                <span asp-validation-for="Fecha" class="text-danger"></span>
            </div>

            <div class="field-block">
                <label class="form-label-modern">Método de Pago</label>
                <input asp-for="Metodo" type="hidden" id="MetodoHidden" />

                <div class="method-grid">
                    <button type="button" class="method-btn" data-method="Efectivo">Efectivo</button>
                    <button type="button" class="method-btn" data-method="Transferencia">Transferencia</button>
                    <button type="button" class="method-btn" data-method="Tarjeta">Tarjeta</button>
                </div>

                <span asp-validation-for="Metodo" class="text-danger"></span>
            </div>

            <div class="field-block">
                <label asp-for="Notas" class="form-label-modern">Notas</label>
                <div class="input-shell">
                    <span class="input-icon" style="top: 24px; transform:none;">💬</span>
                    <textarea asp-for="Notas" class="form-textarea-modern" placeholder="Observaciones adicionales del pago"></textarea>
                </div>
                <span asp-validation-for="Notas" class="text-danger"></span>
            </div>

            <div class="actions-row">
                <a asp-action="Index" class="btn-cancel-modern">Cancelar</a>
                <button type="submit" class="btn-submit-modern">Registrar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function () {
            const hiddenMetodo = document.getElementById('MetodoHidden');
            const buttons = document.querySelectorAll('.method-btn');

            function activarMetodo(valor) {
                buttons.forEach(btn => {
                    const activo = btn.getAttribute('data-method') === valor;
                    btn.classList.toggle('active', activo);
                });
            }

            buttons.forEach(btn => {
                btn.addEventListener('click', function () {
                    const method = this.getAttribute('data-method');
                    hiddenMetodo.value = method;
                    activarMetodo(method);
                });
            });

            if (hiddenMetodo.value) {
                activarMetodo(hiddenMetodo.value);
            }
        })();
    </script>
}